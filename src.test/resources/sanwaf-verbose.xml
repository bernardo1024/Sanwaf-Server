<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>
<!--suppress ALL -->
<sanwaf>
    <global-settings>
        <enabled>true</enabled>
        <verbose>true</verbose>
    </global-settings>
    <shields>
        <shield>
            <shield-settings>
                <name>XSS</name>
                <minLen>4</minLen>
                <maxLen>9999</maxLen>
            </shield-settings>
            <regex-config>
                <minLen>4</minLen>
                <forceStringPatterns>
                    <enabled>false</enabled>
                    <exclusions>
                        <item>StringExcluded</item>
                    </exclusions>
                </forceStringPatterns>
                <stringPatterns>
                    <item>
                        <key>xss-form-elements</key>
                        <value><![CDATA[(?:(?:<|(?:\\|%5C)(?:0|(?:%30)){0,1}(?:7|%37)(?:4|%34)|(?:%|(?:\\|%5C)(?:(?:x|%[75]8)|(?:(?:(?:u)|(?:%)[75]5)(?:0|(?:%30)){2})))3c)|(?:<|(?:\\|%5C)(?:0|(?:%30)){0,1}(?:7|%37)(?:4|%34)|(?:%|(?:\\|%5C)(?:(?:x|%[75]8)|(?:(?:(?:u)|(?:%)[75]5)(?:0|(?:%30)){2})))3c)(?:\/|(?:\\|%5C)(?:0|(?:%30)){0,1}(?:5|%35)(?:7|%37)|(?:%|(?:\\|%5C)(?:(?:x|%[75]8)|(?:(?:(?:u)|(?:%)[75]5)(?:0|(?:%30)){2})))2f))(?:[^\s\/]{1}.+)(?:>|(?:\\|%5C)(?:0|(?:%30)){0,1}(?:7|%37)(?:6|%36)|(?:%|(?:\\|%5C)(?:(?:x|%[75]8)|(?:(?:(?:u)|(?:%)[75]5)(?:0|(?:%30)){2})))3e)]]></value>
                    </item>
                </stringPatterns>
                <customPatterns>
                    <item>
                        <key>date</key>
                        <value><![CDATA[^\d{4}\-(?:0?[1-9]|1[012])\-(?:0?[1-9]|[12][0-9]|3[01])$]]></value>
                    </item>
                </customPatterns>
            </regex-config>
            <metadata>
                <enabled>
                    <parameters>true</parameters>
                </enabled>
                <secured>
                    <endpoints>
                        <endpoint>
                            <strict>less</strict>
                            <uri>/foo/bar/strictWithLessWord.jsp</uri>
                            <items>
                                <item>
                                    <name>parm1</name>
                                    <type>s</type>
                                </item>
                                <item>
                                    <name>parm2</name>
                                    <type>s</type>
                                </item>
                                <item>
                                    <name>parm3</name>
                                    <type>s</type>
                                </item>
                            </items>
                        </endpoint>
                    </endpoints>
                    <parameters>
                        <item>
                            <name>Numeric</name>
                            <type>n</type>
                        </item>
                        <item>
                            <name>Alphanumeric</name>
                            <type>a</type>
                        </item>
                    </parameters>
                </secured>
            </metadata>
        </shield>
    </shields>
</sanwaf>

